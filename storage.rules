rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Drive uploads: path = drive/{companyCode}/{uid}/{docId}/{fileName}
    // Write: only the uploader (uid in path must match auth uid)
    // Read: any signed-in user (download URLs are already token-protected)
    match /drive/{companyCode}/{uid}/{docId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
